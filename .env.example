# Copy to .env or Cursor_Railway_airlock.env and fill in values.
# Railway: set these in the dashboard (use secrets for GITHUB_TOKEN).

GITHUB_TOKEN=your_personal_access_token_with_repo_scope
GITHUB_REPO=cornonthe15-cyber/Data_exports

# Optional: path prefix inside the repo for MCP server (logs and drawings)
DATA_PATH=
# Optional: path for technical drawings only (defaults to DATA_PATH)
# DRAWINGS_PATH=drawings

# Upload script (upload_exports_to_github.py): local folder where you save export files
EXPORTS_FOLDER=
# Optional: repo to upload to (default: cornonthe15-cyber/Data_exports)
# DATA_EXPORTS_REPO=cornonthe15-cyber/Data_exports

# PORT is set by Railway for the MCP server
# PORT=8000
